# Copy to .env on the server and fill in real values. Never commit the real .env.
# (.env is git-ignored; this .example template is the documented exception.)

# --- Tailscale (production sidecar) ---
# Reusable auth key from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# --- KIE.ai (Seedance / Kling / GPT-Image) ---
KIE_API_KEY=

# --- Supabase (NEXT_PUBLIC_* are used both as Docker build args AND at runtime) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- TTS providers ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# --- HeyGen ---
HEYGEN_API_KEY=

# --- Outbound proxy for Google calls (optional) ---
HTTPS_PROXY=
