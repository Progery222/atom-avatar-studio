# Copy to .env on the server and fill in real values. Never commit the real .env.
# (.env is git-ignored; this .example template is the documented exception.)

# --- Tailscale (production sidecar) ---
# Reusable auth key from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=

# --- KIE.ai (Seedance / Kling / GPT-Image) ---
KIE_API_KEY=

# --- Object storage (self-hosted MinIO, S3-compatible) ---
# MinIO container root credentials:
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
# App S3 client — use the SAME values as MINIO_ROOT_USER / MINIO_ROOT_PASSWORD:
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=media
# Public base URL of the app; uploaded files are served at <PUBLIC_BASE_URL>/api/files/<key>
PUBLIC_BASE_URL=https://atom-avatar.tailef595f.ts.net

# --- TTS providers ---
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY=
GEMINI_API_KEY_2=

# --- HeyGen ---
HEYGEN_API_KEY=

# --- Optional outbound proxy for Google/Gemini calls ---
# Leave unset unless required. NOTE: a value here also routes the Docker build
# through the proxy, so only set it if the proxy is reachable from the server.
# HTTPS_PROXY=

# --- External REST API (/api/v1) ---
# Kill switch — set to "false" to disable the whole /api/v1 surface (default: enabled).
EXTERNAL_API_ENABLED=true
# Per-API-key request budget per minute.
EXTERNAL_API_RATE_LIMIT_PER_MINUTE=120
# Public base URL advertised in the OpenAPI `servers` block (usually = PUBLIC_BASE_URL).
EXTERNAL_API_PUBLIC_BASE_URL=https://atom-avatar.tailef595f.ts.net
# Pepper for HMAC-SHA256 hashing of API keys. REQUIRED. Generate: openssl rand -hex 32
EXTERNAL_API_KEY_HASH_SECRET=
# Optional: pre-seed the first API key on an empty DB. Put the RAW key here (the app
# hashes it on startup). Provisioning path for containerized prod (no CLI in the image).
# Generate: echo "atom_live_$(openssl rand -base64 32 | tr '+/' '-_' | tr -d '=')"
# Remove after the first boot once you've stored the key.
# EXTERNAL_API_BOOTSTRAP_KEY=

# --- API metadata database (self-hosted PostgreSQL) ---
# Credentials for the `postgres` compose service:
POSTGRES_DB=atom_api
POSTGRES_USER=atom
POSTGRES_PASSWORD=
# Connection string. In compose the host is the `postgres` service; for local
# `npm run dev` against `docker compose up postgres` use host localhost.
# Compose (app):  postgresql://atom:PASSWORD@postgres:5432/atom_api
# Local dev:      postgresql://atom:PASSWORD@localhost:5432/atom_api
DATABASE_URL=postgresql://atom:CHANGE_ME@localhost:5432/atom_api

# --- Retention cleanup (media + ephemeral DB rows) ---
# Files in the MinIO bucket and generation/idempotency rows older than this many
# days are deleted by the in-app scheduler. Default 3.
CLEANUP_RETENTION_DAYS=3
# Cron expression for the daily sweep (default: 03:00 every day).
# CLEANUP_CRON=0 3 * * *
